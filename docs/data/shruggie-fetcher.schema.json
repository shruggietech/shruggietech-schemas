{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://schemas.shruggie.tech/data/shruggie-fetcher.schema.json",
    "title": "Shruggie Fetcher Target Schema (v1)",
    "description": "Defines recurring fetch targets and request/runtime conditions for automated data collection across current and future endpoints.",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "schema_version",
        "targets"
    ],
    "properties": {
        "$schema": {
            "type": "string",
            "title": "Instance Schema URI",
            "description": "Optional schema URI pointer for tooling and editor validation.",
            "format": "uri",
            "examples": [
                "https://schemas.shruggie.tech/data/shruggie-fetcher.schema.json"
            ]
        },
        "schema_version": {
            "type": "string",
            "title": "Schema Version",
            "description": "Human-readable schema contract version for configuration lifecycle management.",
            "const": "1.0.0",
            "examples": [
                "1.0.0"
            ]
        },
        "generated_by": {
            "type": "string",
            "title": "Generated By",
            "description": "System or process that created this configuration file.",
            "examples": [
                "world-monitor bootstrap"
            ]
        },
        "generated_at": {
            "type": "string",
            "title": "Generated Timestamp",
            "description": "ISO-8601 timestamp indicating when this configuration document was generated.",
            "format": "date-time",
            "examples": [
                "2026-04-05T18:30:00Z"
            ]
        },
        "targets": {
            "type": "array",
            "title": "Fetch Targets",
            "description": "List of endpoint targets that should be fetched on recurring schedules.",
            "minItems": 1,
            "items": {
                "$ref": "#/definitions/target"
            }
        }
    },
    "definitions": {
        "target": {
            "type": "object",
            "title": "Target",
            "description": "Configuration for one endpoint fetch target.",
            "additionalProperties": false,
            "required": [
                "url",
                "frequency_human",
                "frequency_cron",
                "conditions"
            ],
            "properties": {
                "id": {
                    "type": "string",
                    "title": "Target Identifier",
                    "description": "Stable unique identifier for this target.",
                    "pattern": "^[a-z0-9][a-z0-9_-]{1,63}$",
                    "examples": [
                        "wm_iss"
                    ]
                },
                "enabled": {
                    "type": "boolean",
                    "title": "Enabled",
                    "description": "Whether this target is active for scheduling.",
                    "default": true
                },
                "name": {
                    "type": "string",
                    "title": "Display Name",
                    "description": "Human-readable name for operators.",
                    "minLength": 1,
                    "examples": [
                        "ISS Position"
                    ]
                },
                "url": {
                    "type": "string",
                    "title": "Endpoint URL",
                    "description": "Absolute URL for the endpoint to fetch.",
                    "format": "uri",
                    "minLength": 1,
                    "examples": [
                        "https://world-monitor.com/api/iss"
                    ]
                },
                "method": {
                    "type": "string",
                    "title": "HTTP Method",
                    "description": "HTTP method used for the request.",
                    "enum": [
                        "GET",
                        "POST",
                        "PUT",
                        "PATCH",
                        "DELETE",
                        "HEAD"
                    ],
                    "default": "GET"
                },
                "frequency_human": {
                    "type": "string",
                    "title": "Human Frequency",
                    "description": "Operator-friendly schedule string.",
                    "minLength": 1,
                    "examples": [
                        "Every 1 minute"
                    ]
                },
                "frequency_cron": {
                    "type": "string",
                    "title": "Cron Frequency",
                    "description": "Cron expression used by the scheduler. Supports common 5-field cron syntax.",
                    "pattern": "^\\S+\\s+\\S+\\s+\\S+\\s+\\S+\\s+\\S+$",
                    "examples": [
                        "*/1 * * * *"
                    ]
                },
                "conditions": {
                    "$ref": "#/definitions/conditions"
                },
                "parse": {
                    "$ref": "#/definitions/parse"
                },
                "metadata": {
                    "$ref": "#/definitions/metadata"
                }
            }
        },
        "conditions": {
            "type": "object",
            "title": "Request and Runtime Conditions",
            "description": "Additional request, protocol, and runtime controls for endpoint fetching.",
            "additionalProperties": false,
            "properties": {
                "headers": {
                    "type": "object",
                    "title": "HTTP Headers",
                    "description": "Headers to include in outgoing requests.",
                    "additionalProperties": {
                        "type": "string"
                    },
                    "examples": [
                        {
                            "Accept": "application/json"
                        }
                    ]
                },
                "user_agent": {
                    "type": "string",
                    "title": "User Agent",
                    "description": "Custom User-Agent string for endpoint access policies.",
                    "minLength": 1,
                    "examples": [
                        "ShruggieFetcher/1.0 (+https://world-monitor.com)"
                    ]
                },
                "auth": {
                    "$ref": "#/definitions/auth"
                },
                "cors": {
                    "$ref": "#/definitions/cors"
                },
                "query_params": {
                    "type": "object",
                    "title": "Query Parameters",
                    "description": "Static query parameters appended to requests.",
                    "additionalProperties": {
                        "type": [
                            "string",
                            "number",
                            "boolean"
                        ]
                    }
                },
                "request_body": {
                    "type": [
                        "object",
                        "array",
                        "string",
                        "number",
                        "boolean",
                        "null"
                    ],
                    "title": "Request Body",
                    "description": "Payload used for non-GET requests when applicable."
                },
                "timeout_ms": {
                    "type": "integer",
                    "title": "Timeout (ms)",
                    "description": "Maximum request duration in milliseconds.",
                    "minimum": 100,
                    "maximum": 300000,
                    "default": 15000
                },
                "retry": {
                    "$ref": "#/definitions/retry"
                },
                "accepted_status_codes": {
                    "type": "array",
                    "title": "Accepted Status Codes",
                    "description": "HTTP status codes treated as successful by the fetcher.",
                    "minItems": 1,
                    "uniqueItems": true,
                    "items": {
                        "type": "integer",
                        "minimum": 100,
                        "maximum": 599
                    },
                    "default": [
                        200
                    ]
                },
                "expected_content_types": {
                    "type": "array",
                    "title": "Expected Content Types",
                    "description": "Accepted response Content-Type values.",
                    "minItems": 1,
                    "uniqueItems": true,
                    "items": {
                        "type": "string",
                        "minLength": 1
                    },
                    "examples": [
                        [
                            "application/json"
                        ]
                    ]
                },
                "rate_limit": {
                    "$ref": "#/definitions/rate_limit"
                }
            }
        },
        "auth": {
            "type": "object",
            "title": "Authentication",
            "description": "Authentication strategy for endpoint requests.",
            "additionalProperties": false,
            "required": [
                "mode"
            ],
            "properties": {
                "mode": {
                    "type": "string",
                    "title": "Auth Mode",
                    "description": "Authentication strategy type.",
                    "enum": [
                        "none",
                        "apiKey",
                        "bearer",
                        "basic",
                        "oauth2"
                    ],
                    "default": "none"
                },
                "header_name": {
                    "type": "string",
                    "title": "Header Name",
                    "description": "Header that carries the auth token or key when applicable.",
                    "examples": [
                        "Authorization"
                    ]
                },
                "token_env": {
                    "type": "string",
                    "title": "Token Environment Variable",
                    "description": "Environment variable name containing the token or key.",
                    "pattern": "^[A-Z_][A-Z0-9_]*$",
                    "examples": [
                        "WORLD_MONITOR_API_KEY"
                    ]
                },
                "username_env": {
                    "type": "string",
                    "title": "Username Environment Variable",
                    "description": "Environment variable containing the username for basic auth.",
                    "pattern": "^[A-Z_][A-Z0-9_]*$"
                },
                "password_env": {
                    "type": "string",
                    "title": "Password Environment Variable",
                    "description": "Environment variable containing the password for basic auth.",
                    "pattern": "^[A-Z_][A-Z0-9_]*$"
                }
            }
        },
        "cors": {
            "type": "object",
            "title": "CORS Support",
            "description": "Cross-origin access expectations, mainly for browser-based workers.",
            "additionalProperties": false,
            "required": [
                "required"
            ],
            "properties": {
                "required": {
                    "type": "boolean",
                    "title": "CORS Required",
                    "description": "True when fetch execution context requires CORS-compatible responses."
                },
                "supports_credentials": {
                    "type": "boolean",
                    "title": "Supports Credentials",
                    "description": "Whether credentialed CORS requests are supported or expected.",
                    "default": false
                },
                "notes": {
                    "type": "string",
                    "title": "CORS Notes",
                    "description": "Implementation notes for CORS behavior."
                }
            }
        },
        "retry": {
            "type": "object",
            "title": "Retry Policy",
            "description": "Retry behavior for transient failures.",
            "additionalProperties": false,
            "required": [
                "max_attempts",
                "backoff_strategy"
            ],
            "properties": {
                "max_attempts": {
                    "type": "integer",
                    "title": "Max Attempts",
                    "description": "Maximum retry attempts after the initial request.",
                    "minimum": 0,
                    "maximum": 20,
                    "default": 3
                },
                "initial_delay_ms": {
                    "type": "integer",
                    "title": "Initial Delay (ms)",
                    "description": "Initial retry delay in milliseconds.",
                    "minimum": 0,
                    "maximum": 600000,
                    "default": 1000
                },
                "backoff_strategy": {
                    "type": "string",
                    "title": "Backoff Strategy",
                    "description": "Algorithm used to increase delay between retries.",
                    "enum": [
                        "fixed",
                        "linear",
                        "exponential"
                    ],
                    "default": "exponential"
                },
                "jitter": {
                    "type": "boolean",
                    "title": "Jitter",
                    "description": "Whether to randomize retry delay to reduce thundering herd effects.",
                    "default": true
                }
            }
        },
        "rate_limit": {
            "type": "object",
            "title": "Rate Limit Expectations",
            "description": "Known provider-side limits to help avoid over-fetching.",
            "additionalProperties": false,
            "properties": {
                "max_requests": {
                    "type": "integer",
                    "title": "Max Requests",
                    "description": "Maximum number of requests allowed in the given window.",
                    "minimum": 1
                },
                "per_seconds": {
                    "type": "integer",
                    "title": "Window Seconds",
                    "description": "Duration of the rate-limit window in seconds.",
                    "minimum": 1
                }
            }
        },
        "parse": {
            "type": "object",
            "title": "Parsing Hints",
            "description": "Hints for downstream parsing and normalization components.",
            "additionalProperties": false,
            "properties": {
                "format": {
                    "type": "string",
                    "title": "Payload Format",
                    "description": "Expected payload format for parser selection.",
                    "enum": [
                        "json",
                        "xml",
                        "rss",
                        "html",
                        "text"
                    ],
                    "default": "json"
                },
                "root_path": {
                    "type": "string",
                    "title": "Root Path",
                    "description": "Optional JSONPath/XPath-like hint to the records collection.",
                    "examples": [
                        "$.items"
                    ]
                },
                "charset": {
                    "type": "string",
                    "title": "Character Set",
                    "description": "Expected text encoding for decoding payload content.",
                    "examples": [
                        "utf-8"
                    ]
                }
            }
        },
        "metadata": {
            "type": "object",
            "title": "Operational Metadata",
            "description": "Optional metadata used for ownership, classification, and reporting.",
            "additionalProperties": false,
            "properties": {
                "source_system": {
                    "type": "string",
                    "title": "Source System",
                    "description": "Logical source grouping name.",
                    "examples": [
                        "world-monitor"
                    ]
                },
                "owner": {
                    "type": "string",
                    "title": "Owner",
                    "description": "Responsible team, service, or individual.",
                    "examples": [
                        "observability-team"
                    ]
                },
                "priority": {
                    "type": "string",
                    "title": "Priority",
                    "description": "Operational importance used for scheduling and alerting.",
                    "enum": [
                        "low",
                        "normal",
                        "high",
                        "critical"
                    ],
                    "default": "normal"
                },
                "tags": {
                    "type": "array",
                    "title": "Tags",
                    "description": "Freeform labels for filtering and reporting.",
                    "items": {
                        "type": "string",
                        "minLength": 1
                    },
                    "uniqueItems": true
                },
                "notes": {
                    "type": "string",
                    "title": "Notes",
                    "description": "Additional operator notes for this target."
                }
            }
        }
    },
    "examples": [
        {
            "schema_version": "1.0.0",
            "targets": [
                {
                    "id": "wm_iss",
                    "name": "ISS Position",
                    "url": "https://world-monitor.com/api/iss",
                    "method": "GET",
                    "frequency_human": "Every 1 minute",
                    "frequency_cron": "*/1 * * * *",
                    "conditions": {
                        "headers": {
                            "Accept": "application/json"
                        },
                        "user_agent": "ShruggieFetcher/1.0 (+https://world-monitor.com)",
                        "auth": {
                            "mode": "none"
                        },
                        "cors": {
                            "required": false
                        },
                        "timeout_ms": 10000,
                        "retry": {
                            "max_attempts": 3,
                            "initial_delay_ms": 1000,
                            "backoff_strategy": "exponential",
                            "jitter": true
                        },
                        "accepted_status_codes": [
                            200
                        ],
                        "expected_content_types": [
                            "application/json"
                        ]
                    },
                    "parse": {
                        "format": "json"
                    },
                    "metadata": {
                        "source_system": "world-monitor",
                        "priority": "high",
                        "tags": [
                            "space",
                            "telemetry"
                        ]
                    }
                }
            ]
        }
    ]
}
